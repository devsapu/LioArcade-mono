# BFF base URL (browser)
NEXT_PUBLIC_BFF_URL=http://localhost:4000

# FusionAuth base URL (browser) — admin UI and OAuth endpoints
NEXT_PUBLIC_FUSIONAUTH_URL=http://localhost:9011

# FusionAuth OAuth Application → Client Id (public)
NEXT_PUBLIC_FUSIONAUTH_CLIENT_ID=

# Optional: fixed redirect URI (must match FusionAuth authorized redirect URLs exactly)
# NEXT_PUBLIC_FUSIONAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
